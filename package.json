{
  "name": "new-project",
  "version": "1.0.0",
  "description": "Love Simulator web game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "release:check": "node ./scripts/release-check.mjs",
    "release:preview": "npm run release:check && npm run preview -- --host 0.0.0.0 --port 4173",
    "test:playwright-client": "node ./web_game_playwright_client.js --url http://127.0.0.1:4173 --click-selector '#quick-start-btn' --actions-file actions_enter.json --iterations 1 --pause-ms 300 --screenshot-dir output/web-game --headless true"
  },
  "keywords": [
    "love",
    "simulator",
    "web-game"
  ],
  "author": "codex",
  "license": "ISC",
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
